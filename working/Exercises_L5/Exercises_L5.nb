Cell[CellGroupData[{

Cell["Exercise 2", "Subsection",
 CellChangeTimes->{{3.9905465289053745`*^9, 3.9905465317875214`*^9}, 
   3.990546657241869*^9},ExpressionUUID->"e535a0fb-52cd-ca43-8e1f-\
504c73f82734"],

Cell[TextData[{
 "Q2: Integrate the expression f(x) = sin(x) ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"-", "x"}]], TraditionalForm]],ExpressionUUID->
  "0d4eef0c-cc46-1246-8e6e-bbd330ccc94a"],
 ", and then take its derivative."
}], "Text",
 CellChangeTimes->{{3.99054660443902*^9, 
  3.990546608327751*^9}},ExpressionUUID->"f1d13085-b4ce-df49-bf0d-\
ba3880183058"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", "x"}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"F", "[", "x_", "]"}], "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], ",", "x"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Fp", "[", "x_", "]"}], "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"F", "[", "x", "]"}], ",", "x"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Function: f(x) = \>\"", ",", 
    RowBox[{"f", "[", "x", "]"}]}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Primitive function: F(x) = \>\"", ",", 
    RowBox[{"F", "[", "x", "]"}]}], "]"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Derivative of the primitive: F'(x) = \>\"", ",", 
   RowBox[{"Fp", "[", "x", "]"}]}], "]"}]}], "Code",
 CellChangeTimes->{{3.9905465502091637`*^9, 3.9905465651791*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"62ad0bce-d65e-bb4b-a13d-489b953d3bca"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Function: f(x) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]], " ", 
    RowBox[{"Sin", "[", "x", "]"}]}]}],
  SequenceForm["Function: f(x) = ", E^(-$CellContext`x) Sin[$CellContext`x]],
  Editable->False]], "Print",
 CellChangeTimes->{{3.9905465759317417`*^9, 3.99054657659816*^9}},
 CellLabel->
  "During evaluation of \
In[7]:=",ExpressionUUID->"1d05f38a-6b99-394e-a8eb-76cce42906b4"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Primitive function: F(x) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "2"]}], " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Cos", "[", "x", "]"}], "+", 
      RowBox[{"Sin", "[", "x", "]"}]}], ")"}]}]}],
  SequenceForm[
  "Primitive function: F(x) = ", Rational[-1, 2] 
   E^(-$CellContext`x) (Cos[$CellContext`x] + Sin[$CellContext`x])],
  Editable->False]], "Print",
 CellChangeTimes->{{3.9905465759317417`*^9, 3.990546576613983*^9}},
 CellLabel->
  "During evaluation of \
In[7]:=",ExpressionUUID->"cc8c357d-fc42-3d4d-9598-0fdb209e1535"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Derivative of the primitive: F'(x) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]], " ", 
    RowBox[{"Sin", "[", "x", "]"}]}]}],
  SequenceForm[
  "Derivative of the primitive: F'(x) = ", E^(-$CellContext`x) 
   Sin[$CellContext`x]],
  Editable->False]], "Print",
 CellChangeTimes->{{3.9905465759317417`*^9, 3.990546576613983*^9}},
 CellLabel->
  "During evaluation of \
In[7]:=",ExpressionUUID->"f85e3f01-ac02-7f4c-8f35-ecca5d038ab3"]
