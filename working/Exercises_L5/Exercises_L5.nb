Cell[CellGroupData[{

Cell["Exercise 3", "Subsection",
 CellChangeTimes->{{3.9905466407065697`*^9, 
  3.990546643909889*^9}},ExpressionUUID->"fe31424c-9506-634b-ad7c-\
238e78d30d58"],

Cell["\<\
Q3: Solve the equation  x ln(x) - 3 x + 10 = 6, both symbolically and \
numerically.\
\>", "Text",
 CellChangeTimes->{
  3.990546689861553*^9},ExpressionUUID->"47a96fc5-a9ae-3b4f-a5a3-\
cb823cd74b88"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"eq", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"x", " ", 
       RowBox[{"Log", "[", "x", "]"}]}], "-", 
      RowBox[{"3", " ", "x"}], "+", "10"}], "==", "6"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Equation: \>\"", ",", "eq"}], "]"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Numeric", " ", "solution"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"xNum", "=", 
    RowBox[{"Sort", "[", 
     RowBox[{"x", "/.", " ", 
      RowBox[{"NSolve", "[", 
       RowBox[{"eq", ",", "x", ",", "Reals"}], "]"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Numeric solutions = \>\"", ",", "xNum"}], "]"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Simbolic", " ", "solution"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sym", "=", 
    RowBox[{"Reduce", "[", 
     RowBox[{"eq", ",", "x", ",", "Reals"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Symbolic solution: \>\"", ",", "sym"}], "]"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Numeric", " ", "values", " ", "of", " ", "the", " ", "simbolic", " ", 
    "solutions"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"xSym", "=", 
    RowBox[{"Cases", "[", 
     RowBox[{"sym", ",", 
      RowBox[{
       RowBox[{"x", "==", "val_"}], ":>", "val"}], ",", "Infinity"}], "]"}]}],
    ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"xSymNum", "=", 
    RowBox[{"Sort", "[", 
     RowBox[{"N", "[", "xSym", "]"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Numeric values of symbolic solutions = \>\"", ",", 
    "xSymNum"}], "]"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Comparison", " ", "of", " ", "results"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Simbolic and numeric solution matching: \>\"", ",", 
   RowBox[{
    RowBox[{"Sort", "[", "xSymNum", "]"}], "===", 
    RowBox[{"Sort", "[", "xNum", "]"}]}]}], "]"}]}], "Code",
 CellChangeTimes->{3.990546734888195*^9},
 CellLabel->"In[13]:=",ExpressionUUID->"08374a3e-1b58-8e46-bc8d-76977ad8c3ea"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Equation: \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"10", "-", 
     RowBox[{"3", " ", "x"}], "+", 
     RowBox[{"x", " ", 
      RowBox[{"Log", "[", "x", "]"}]}]}], "\[Equal]", "6"}]}],
  SequenceForm[
  "Equation: ", 10 - 3 $CellContext`x + $CellContext`x Log[$CellContext`x] == 
   6],
  Editable->False]], "Print",
 CellChangeTimes->{3.9905467388087254`*^9},
 CellLabel->
  "During evaluation of \
In[13]:=",ExpressionUUID->"60195926-2d00-ba40-b36c-bc0572ee7b01"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Numeric solutions = \"\>", "\[InvisibleSpace]", 
   RowBox[{"{", 
    RowBox[{"1.5688309034084709`", ",", "15.522896611261862`"}], "}"}]}],
  SequenceForm[
  "Numeric solutions = ", {1.5688309034084709`, 15.522896611261862`}],
  Editable->False]], "Print",
 CellChangeTimes->{3.9905467394112206`*^9},
 CellLabel->
  "During evaluation of \
In[13]:=",ExpressionUUID->"d4a672f1-7f00-1446-b942-87a33d740620"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Symbolic solution: \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"x", "\[Equal]", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"3", "+", 
       RowBox[{"ProductLog", "[", 
        RowBox[{"-", 
         FractionBox["4", 
          SuperscriptBox["\[ExponentialE]", "3"]]}], "]"}]}]]}], "||", 
    RowBox[{"x", "\[Equal]", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"3", "+", 
       RowBox[{"ProductLog", "[", 
        RowBox[{
         RowBox[{"-", "1"}], ",", 
         RowBox[{"-", 
          FractionBox["4", 
           SuperscriptBox["\[ExponentialE]", "3"]]}]}], "]"}]}]]}]}]}],
  SequenceForm["Symbolic solution: ", 
   Or[$CellContext`x == E^(3 + ProductLog[(-4) E^(-3)]), $CellContext`x == 
    E^(3 + ProductLog[-1, (-4) E^(-3)])]],
  Editable->False]], "Print",
 CellChangeTimes->{3.9905467395698204`*^9},
 CellLabel->
  "During evaluation of \
In[13]:=",ExpressionUUID->"69bae5df-7895-2246-93eb-4dc5e60da969"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Numeric values of symbolic solutions = \"\>", "\[InvisibleSpace]", 
   RowBox[{"{", 
    RowBox[{"1.568830903408471`", ",", "15.52289661126186`"}], "}"}]}],
  SequenceForm[
  "Numeric values of symbolic solutions = ", {1.568830903408471, 
   15.52289661126186}],
  Editable->False]], "Print",
 CellChangeTimes->{3.9905467395698204`*^9},
 CellLabel->
  "During evaluation of \
In[13]:=",ExpressionUUID->"547e2659-cc53-c44f-91e3-4d6dc1310c0c"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Simbolic and numeric solution matching: \"\>", "\[InvisibleSpace]",
    "True"}],
  SequenceForm["Simbolic and numeric solution matching: ", True],
  Editable->False]], "Print",
 CellChangeTimes->{3.990546739585705*^9},
 CellLabel->
  "During evaluation of \
In[13]:=",ExpressionUUID->"4d69aa97-08f3-834d-afca-6a97060dd70a"]
